{
  "expo": {
    "name": "Votmean",
    "slug": "Votmean",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.muyheang.Votmean",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "backgroundColor": "#0F172A",
      "package": "com.muyheang.Votmean",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "https://api.bayonhr.shop",
      "eas": {
        "projectId": "4c34da1a-997f-4d3d-9d2e-2eb568505c05"
      }
    }
  }
}
