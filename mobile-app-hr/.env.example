# Backend API URL
# Change this to your computer's local Wi-Fi IP when running on a physical device.
# Examples:
#   Local emulator (Android):  http://10.0.2.2:8080
#   Local emulator (iOS):      http://localhost:8080
#   Physical device:           http://192.168.x.x:8080
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:8080
